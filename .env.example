# ---------------------------------------------------------------------------
# Netolynk — environment variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ---------------------------------------------------------------------------

# Sentry DSN for error tracking (https://sentry.io)
# Leave blank to disable Sentry in development.
VITE_SENTRY_DSN=

# Gemini API key — DO NOT use client-side.
# Route all Gemini calls through a Firebase Cloud Function instead.
# See: https://firebase.google.com/docs/functions/get-started
# GEMINI_API_KEY=   <-- server-side only, never expose to the browser

# Production URL (used for og:url meta tag if you make it dynamic)
VITE_APP_URL=https://netolynk.app

# Cloudinary — free image/video storage for Blinks (no Firebase Storage needed)
# Cloud name and upload preset are PUBLIC — safe to commit or add to Vercel
VITE_CLOUDINARY_CLOUD_NAME=dmwnywqes
VITE_CLOUDINARY_UPLOAD_PRESET=blinks
