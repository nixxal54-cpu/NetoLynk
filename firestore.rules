// ===============================================================
// 🔥 Lynks (FIXED + SECURE)
// ===============================================================

match /lynks/{lynkId} {
  allow read: if true;

  allow create: if isAuthenticated()
    && request.resource.data.userId == request.auth.uid
    && request.resource.data.duration >= 5
    && request.resource.data.duration <= 60;

  allow update: if isAuthenticated() &&
                request.auth.uid == resource.data.userId;

  allow delete: if false;
}

match /lynkLikes/{likeId} {
  allow read: if isAuthenticated();
  allow write: if isAuthenticated()
    && likeId == request.resource.data.lynkId + '_' + request.auth.uid;
}

match /lynkComments/{commentId} {
  allow read: if true;

  allow create: if isAuthenticated()
    && request.resource.data.userId == request.auth.uid
    && request.resource.data.text.size() <= 500;

  allow delete: if isAuthenticated()
    && resource.data.userId == request.auth.uid;
}

match /lynkViews/{viewId} {
  allow read, write: if isAuthenticated();
}

match /watchTimeLogs/{logId} {
  allow read: if isAuthenticated();

  allow create: if isAuthenticated()
    && request.resource.data.userId == request.auth.uid;
}

match /lynkSaves/{saveId} {
  allow read, write: if isAuthenticated();
}

match /lynkReports/{reportId} {
  allow read: if false;

  allow create: if isAuthenticated()
    && request.resource.data.userId == request.auth.uid;
}


// ===============================================================
// ⚡ Blinks (MERGED + SECURE)
// ===============================================================

match /blinks/{blinkId} {

  allow read: if isAuthenticated() &&
              request.time < resource.data.expiresAt;

  allow create: if isAuthenticated() &&
    request.resource.data.userId == request.auth.uid &&
    request.resource.data.mediaUrl is string &&
    request.resource.data.type in ['image', 'video'] &&
    request.resource.data.expiresAt is timestamp &&
    request.resource.data.expiresAt > request.time &&
    request.resource.data.viewsCount == 0 &&
    request.resource.data.viewedBy is list &&
    request.resource.data.viewedBy.size() == 0;

  allow delete: if isDocOwner();

  allow update: if isAuthenticated() && (

    // Owner full control (except userId change)
    (
      isDocOwner() &&
      request.resource.data.userId == resource.data.userId
    )

    ||

    // Secure view tracking
    (
      request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['viewedBy', 'viewsCount']) &&

      request.resource.data.viewedBy is list &&

      request.resource.data.viewedBy.size() ==
        resource.data.viewedBy.size() + 1 &&

      request.resource.data.viewedBy.hasAll(resource.data.viewedBy) &&

      request.auth.uid in request.resource.data.viewedBy &&

      !(request.auth.uid in resource.data.viewedBy) &&

      request.resource.data.viewsCount ==
        resource.data.viewsCount + 1
    )
  );

  // ── Reactions ──
  match /reactions/{reactionId} {
    allow read: if isAuthenticated();

    allow create: if isAuthenticated() &&
      request.resource.data.userId == request.auth.uid &&
      request.resource.data.type in ['like', 'love', 'haha', 'wow', 'sad'];

    allow delete: if isAuthenticated() &&
      resource.data.userId == request.auth.uid;
  }

  // ── Replies ──
  match /replies/{replyId} {
    allow read: if isAuthenticated();

    allow create: if isAuthenticated() &&
      request.resource.data.senderId == request.auth.uid &&
      request.resource.data.text is string &&
      request.resource.data.text.size() <= 1000;

    allow delete: if isAuthenticated() &&
      resource.data.senderId == request.auth.uid;
  }
}
